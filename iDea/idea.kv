#: import WipeTransition kivy.uix.screenmanager.WipeTransition
<RootWidget>:
    id: sm
    transition: WipeTransition()
    current: "Screen1"
    duration: 500
    Screen1:
    Screen2:
    Screen3:

<IdeaLabel1@Label>:
    size_hint: .4, .3
    font_size: "100dp"
    font_name: "fonts/Montserrat-Bold.ttf" 
    color: (0, 0, 0, 1)  

<IdeaLabel2@Label>:
    size_hint: .4, .3
    font_size: "100dp"
    font_name: "fonts/Montserrat-Bold.ttf" 
    color: (1, 1, 1, 1)  


    


<Screen1>:
    on_touch_down: root.manager.current = "Screen2"
    name: "Screen1"
    canvas.before:
        PushMatrix:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            size: self.size
            pos: self.pos
    canvas.after:
        PopMatrix:
    FloatLayout:
        IdeaLabel1:
            id: idealabel1
            text: "iDea"
            pos_hint: {'center_y':0.5, 'center_x': 0.5}

<Screen2>:
    on_enter: app.start_ideaLabel2_animation()
    name: "Screen2"
    canvas.before:
        PushMatrix:
        Color:
            rgba: 0, 0, 0, 1
        Rectangle:
            size: self.size
            pos: self.pos
    canvas.after:
        PopMatrix:
    FloatLayout:
        IdeaLabel2:
            id: idealabel2
            text: "iDea"
            pos_hint: {'center_y':0.5, 'center_x': 0.5}
            
<Screen3>:
    name: "Screen3"
    canvas.before:
        PushMatrix:
        Color:
            rgba: 0, 0, 0, 0
        Rectangle:
            size: self.size
            pos: self.pos
    canvas.after:
        PopMatrix:
    FloatLayout:
        IdeaLabel2:
            id: idealabel2_complete
            text: "iDea"
            pos_hint: {'center_y':0.97, 'center_x': 0.5}
            font_size: "30dp"
        BoxLayout:
            orientation: 'vertical'
            size_hint: .5, .4
            pos_hint: {'center_x': 0.27, 'center_y': 0.725}
            Label:
                id: share
                text: "Share"
                font_name: "Arial"
                font_size: "75dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
            Label:
                id: information
                text: "Information"
                font_name: "Arial"
                font_size: "75dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left':1}

            Label:
                id: easily
                text: "Easily"
                font_name: "Arial"
                font_size: "75dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left':1}
            Label:
                id: within_mtu
                text: "Within MTU"
                font_name: "Arial"
                font_size: "75dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left':1}
        BoxLayout:
            orientation: "vertical"
            size_hint: .5, .1
            pos_hint: {'center_x': 0.27, 'center_y': 0.45}
            Label:
                id: second_text_first_line
                text: "Our chat app is the perfect way to"
                font_name: "fonts/Montserrat-Light.ttf"
                font_size: "20dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
                color: (185/255, 193/255, 190/255, 1)
            Label:
                id: second_text_second_line
                text: "stay informed about Lectures and"
                font_name: "fonts/Montserrat-Light.ttf"
                font_size: "20dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
                color: (185/255, 193/255, 190/255, 1)
            Label:
                id: second_text_third_line
                text: "school activites"
                font_name: "fonts/Montserrat-Light.ttf"
                font_size: "20dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
                color: (185/255, 193/255, 190/255, 1)

            