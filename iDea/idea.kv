#: import WipeTransition kivy.uix.screenmanager.WipeTransition
#: import get_color_from_hex kivy.utils.get_color_from_hex
<RootWidget>:
    id: sm
    transition: WipeTransition()
    current: "Screen1"
    duration: 500
    Screen1:
    Screen2:
    Screen3:
    Screen4:
    Screen5:
    Screen6:
    Screen7:

<IdeaLabel1@Label>:
    size_hint: .4, .3
    font_size: "100dp"
    font_name: "fonts/Montserrat-Bold.ttf" 
    color: (0, 0, 0, 1)  

<IdeaLabel2@Label>:
    size_hint: .4, .3
    font_size: "100dp"
    font_name: "fonts/Montserrat-Bold.ttf" 
    color: (1, 1, 1, 1)  


    


<Screen1>:
    #on_touch_down: root.manager.current = "Screen2"
    
    name: "Screen1"
    canvas.before:
        PushMatrix:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            size: self.size
            pos: self.pos
    canvas.after:
        PopMatrix:
    FloatLayout:
        IdeaLabel1:
            id: idealabel1
            text: "iDea"
            pos_hint: {'center_y':0.5, 'center_x': 0.5}

<Screen2>:
    on_enter: app.start_ideaLabel2_animation()
    name: "Screen2"
    canvas.before:
        PushMatrix:
        Color:
            rgba: 0, 0, 0, 1
        Rectangle:
            size: self.size
            pos: self.pos
    canvas.after:
        PopMatrix:
    FloatLayout:
        IdeaLabel2:
            id: idealabel2
            text: "iDea"
            pos_hint: {'center_y':0.5, 'center_x': 0.5}
            
<Screen3>:
    name: "Screen3"
    canvas.before:
        PushMatrix:
        Color:
            rgba: 0, 0, 0, 1
        Rectangle:
            size: self.size
            pos: self.pos
    canvas.after:
        PopMatrix:
    FloatLayout:
        IdeaLabel2:
            id: idealabel2_complete
            text: "iDea"
            pos_hint: {'center_y':0.97, 'center_x': 0.5}
            font_size: "30dp"
        BoxLayout:
            orientation: 'vertical'
            size_hint: .5, .4
            pos_hint: {'center_x': 0.3, 'center_y': 0.725}
            Label:
                id: share
                text: "Share"
                font_name: "Arial"
                font_size: "66dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
            Label:
                id: information
                text: "Information"
                font_name: "Arial"
                font_size: "66dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left':1}

            Label:
                id: easily
                text: "Easily"
                font_name: "Arial"
                font_size: "66dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left':1}
            Label:
                id: within_mtu
                text: "Within MTU"
                font_name: "Arial"
                font_size: "66dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left':1}
        BoxLayout:
            orientation: "vertical"
            size_hint: .5, .1
            pos_hint: {'center_x': 0.3, 'center_y': 0.45}
            Label:
                id: second_text_first_line
                text: "Our chat app is the perfect way to"
                font_name: "fonts/Montserrat-Light.ttf"
                font_size: "20dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
                color: (185/255, 193/255, 190/255, 1)
            Label:
                id: second_text_second_line
                text: "stay informed about Lectures and"
                font_name: "fonts/Montserrat-Light.ttf"
                font_size: "20dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
                color: (185/255, 193/255, 190/255, 1)
            Label:
                id: second_text_third_line
                text: "school activites"
                font_name: "fonts/Montserrat-Light.ttf"
                font_size: "20dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
                color: (185/255, 193/255, 190/255, 1)
        BoxLayout:
            orientation: "vertical"
            size_hint: .9, .07
            pos_hint: {'center_x': 0.5, 'center_y': 0.2}
            SmoothButton:
                id: sign_up_button
                text:"Sign Up"
                font_name: 'Arial'
                font_size: "15dp"
                color: (0, 14/255, 8/255, 1)
                on_touch_down: app.handle_signUp(*args)
                on_press: self.back_color=(0.5, 0.5, 0.5, 1)
                on_release: self.back_color=(1, 1, 1, 1)
        BoxLayout:
            orientation: "horizontal"
            size_hint: .5, .1
            pos_hint: {'center_x': 0.55, 'center_y': 0.1}
            padding: 0
            spacing: 0
            Label:
                id: existing_account
                text: "Existing account?"
                font_name: "fonts/Montserrat-ExtraLight.ttf"
                font_size: '15dp'
                color: (185/255, 193/255, 190/255, 1)
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'right': 0.5}
            Button:
                id: log_in
                text: " Log in"
                font_size: '15dp'
                background_normal: ''
                background_down: ''
                background_color: (0,0,0,0)
                color: (1, 1, 1 ,1 )
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'x': 0.5}
                on_touch_down: app.handle_login(*args)
                on_press:  self.color=(0.5, 0.5, 0.5, 1) #app.handle_press(self)
                on_release: self.color=(1, 1, 1, 1)
<Screen4>:
    name: "Screen4"
    canvas.before:
        PushMatrix:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            size: self.size
            pos: self.pos
    canvas.after:
        PopMatrix:
    FloatLayout:
        Button:
            background_down: ''
            background_normal: ''
            text: ''
            size_hint: None, None
            width: '25dp'
            height: '33dp'
            pos_hint: {'center_x': 0.1, 'top':0.98}
            on_press: root.manager.current = "Screen3"
            Image:
                source: "images/arrow2.png"
                size: self.parent.size
                pos: self.parent.pos
        BoxLayout:
            orientation: "horizontal"
            size_hint: .5, .1
            pos_hint: {'center_x': 0.5, 'center_y': 0.88}
            padding: 0
            spacing: 0
            Label:
                color: (0, 14/255, 8/255, 1)
                id: to_idea
                text: ' [b]Log in to iDea[/b]'
                font_name: 'Arialbd'
                markup: True
                font_size: "20dp"
                pos_hint: {'x': 0.5}
                design_width: root.width/3
                canvas.before:
                    Color: 
                        rgba: (88/255, 195/255, 182/255, 1)
                    Rectangle:
                        size: 66, 10
                        pos: root.width/2 - 67, self.pos[1] + self.pos[1]/26
        BoxLayout:
            orientation: "vertical"
            size_hint: .5, .07
            pos_hint: {'center_x': 0.3, 'center_y': 0.81}
            Label:
                id: welcome_back
                text: "Welcome back! Sign in using your"
                font_name: "fonts/Montserrat-Light.ttf"
                font_size: "18dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'center_x': 0.9}
                color: (121/255, 124/255, 123/255, 1)
            Label:
                id: matric_no
                text: "matriculation number and password"
                font_name: "fonts/Montserrat-Light.ttf"
                font_size: "18dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'center_x': 0.9}
                color: (121/255, 124/255, 123/255, 1)
        BoxLayout:
            orientation:'vertical'
            size_hint: .5, .1
            pos_hint: {'center_x': 0.3, 'center_y': 0.55}
            Label:
                id: your_matric_no
                font_name: "fonts/Montserrat-Medium.ttf"
                font_size: "18dp"
                text: 'Your matric no'
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
                color: (36/255, 120/255, 109/255, 1)
            TextInput:
                background_normal: ''
                background_active: ''
                background_color: (1, 1, 1, 1) 
                cursor_color: (0, 0, 0, 1)
                border: (10, 10, 10, 10) 
                font_name: "Arial"
                font_size: '19dp'
                size_hint_x: 1.8
                multiline: False
                padding:[0.4, 7,0.4, 0.4]
                canvas.before:
                    PushMatrix:
                    Color:
                        rgba: (205/255, 209/255, 208/255, 1)
                    Rectangle:
                        size: self.width, 1
                        pos: self.pos
                    Color:
                        rgba: (0, 14/255 , 8/255, 1)
                canvas.after:
                    PopMatrix:
        BoxLayout:
            orientation:'vertical'
            size_hint: .5, .1
            pos_hint: {'center_x': 0.3, 'center_y': 0.42}
            Label:
                id: password
                font_name: "fonts/Montserrat-Medium.ttf"
                font_size: "18dp"
                text: 'Password'
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
                color: (36/255, 120/255, 109/255, 1)
            TextInput:
                background_normal: ''
                background_active: ''
                background_color: (1, 1, 1, 1) 
                font_name: "Arial"
                font_size: '19dp'
                cursor_color: (0, 0, 0, 1)
                border: (10, 10, 10, 10) 
                size_hint_x: 1.8
                multiline: False
                padding:[0.4, 7,0.4, 0.4]
                canvas.before:
                    PushMatrix:
                    Color:
                        rgba: (205/255, 209/255, 208/255, 1)
                    Rectangle:
                        size: self.width, 1
                        pos: self.pos
                    Color:
                        rgba: (0, 0, 0, 1)
                canvas.after:
                    PopMatrix:
        BoxLayout:
            orientation: "vertical"
            size_hint: .9, .07
            pos_hint: {'center_x': 0.5, 'center_y': 0.13}
            SmoothButton:
                id: log_in_button2
                text:"Log in"
                back_color: (243/255, 246/255, 246/255, 1)
                font_name: 'Arialbd'
                font_size: "15dp"
                color: (121/255, 124/255, 123/255, 1)
                on_touch_down: app.handle_login2()
                on_press: app.handle_loginBtn2_press() #self.back_color=(36/255, 120/255, 109/255, 1)
                on_release: app.handle_loginBtn2_release() #self.back_color= (243/255, 246/255, 246/255, 1)
        BoxLayout:
            orientation: "vertical"
            pos_hint: {'center_x': 0.5, 'center_y': 0.07}
            size_hint: .9, .02
            Button:
                background_normal: ''
                background_down: ''
                background_color: (1, 1, 1, 1)
                color: (36/255, 120/255, 109/255, 1)
                text: 'Forgot Password?'
                on_press: self.color = (121/255, 124/255, 123/255, 1)
                on_release: self.color = (36/255, 120/255, 109/255, 1)
<Screen5>:
    name: "Screen5"
    canvas.before:
        PushMatrix:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            size: self.size
            pos: self.pos
    canvas.after:
        PopMatrix:
    FloatLayout:
        Button:
            background_down: ''
            background_normal: ''
            text: ''
            size_hint: None, None
            width: '25dp'
            height: '33dp'
            pos_hint: {'right': 0.12, 'top':0.98}
            on_press: root.manager.current = "Screen3"
            Image:
                source: "images/arrow2.png"
                size: self.parent.size
                pos: self.parent.pos

        BoxLayout:
            orientation: "horizontal"
            size_hint: .5, .1
            pos_hint: {'center_x': 0.5, 'center_y': 0.88}
            padding: 0
            spacing: 0
            Label:
                color: (0, 14/255, 8/255, 1)
