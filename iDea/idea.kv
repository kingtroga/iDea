            SmoothButton:
                id: signUpBtn2
                text:"Create an account"
                back_color: (243/255, 246/255, 246/255, 1)
                font_name: 'Arialbd'
                font_size: "15dp"
                color: (121/255, 124/255, 123/255, 1)
