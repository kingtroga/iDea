                    Color:
                        rgba: (0, 14/255 , 8/255, 1)
                canvas.after:
                    PopMatrix:
        BoxLayout:
            orientation:'vertical'
            size_hint: .5, .1
            pos_hint: {'center_x': 0.3, 'center_y': 0.55}
            Label:
                id: matriculation_number
                font_name: "fonts/Montserrat-Medium.ttf"
                font_size: "16dp"
                text: 'Matriculation Number'
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
                color: (36/255, 120/255, 109/255, 1)
            TextInput:
                background_normal: ''
                background_active: ''
                background_color: (1, 1, 1, 1) 
                cursor_color: (0, 0, 0, 1)
                border: (10, 10, 10, 10) 
                font_name: "Arial"
                font_size: '19dp'
                size_hint_x: 1.8
                multiline: False
                padding:[0.4, 7,0.4, 0.4]
                canvas.before:
