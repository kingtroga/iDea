                on_release: app.handle_signUpBtn2_release() #self.back_color= (243/255, 246/255, 246/255, 1)

<Screen6>:
    name: "Screen6"
    #on_enter: app.start_story()
###########################################################################################################################################################################################################################
################################## THE MESSAGE SCREEN ######################################################################################################################################################3##############
###########################################################################################################################################################################################################################
    MDBottomNavigation:
        id: bottom_navigation
        selected_color_background: get_color_from_hex('FFFFFF')
        text_color_active: get_color_from_hex('24786D')
        MDBottomNavigationItem:
            name: 'screen1'
            text: 'Message'
            icon: 'message-processing-outline'
            MDScreen:
                radius: [0, 0, 0, 0]
                id: messages_screen
                md_bg_color: 0, 14/255, 8/255, 1
                
                AnchorLayout:
                    anchor_x: 'center'
                    anchor_y: 'top'
                    MDTopAppBar:
                        title: "Home"
                        id: top_bar_1
                        md_bg_color: 0, 14/255, 8/255, 1
                        left_action_items: [["magnify", "This is the search button"]]
                        specific_text_color: 1, 1, 1, 1
                        right_action_items: [["dots-vertical"]]
                        elevation: 0

                MDFloatLayout:
##################The first part of the MDTopBar##########################################################################################################################################
                    MDIconButton:
                        icon: ''
                        icon_color: 1, 1, 1, 1
                        icon_size: '30dp'
                        theme_icon_color: "Custom"
                        pos_hint: {'right': 0.16, 'top': 0.99}
                        
                        canvas:
                            Color:
                                rgb: 59/255, 63/255, 59/255, 1
                            Line:
                                width: 1
                                circle: (self.center_x, self.center_y, min(self.width-2, self.height-2)/2, 0, 360)
#################The Second part of the MDTopBar###########################################################################################################################################333
                    MDIconButton:
                        icon: '4.jpg'
                        icon_size: '30dp'
                        theme_icon_color: "Custom"
                        pos_hint: {'right': 0.98, 'top': 0.99}
                        
                        canvas:
                            Color: 
                                rgb: 1, 1, 1, 1
                            RoundedRectangle:
                                source: self.icon
                                size: self.size
                                pos: self.pos
                                radius: [50]
                    ScrollView:
                        do_scroll_y: False
                        do_scroll_x: True
                        size_hint_y: .15
                        pos_hint: {"top": .88}
                        bar_width: 0
                        GridLayout:
                            id: grid
                            size_hint_x: None
                            height: self.minimum_height
                            width: self.minimum_width
                            rows: 1
                            spacing: 25
                            padding: 20, 15

                    MDBoxLayout:
                        md_bg_color: 1, 1, 1, 1
                        orientation: "vertical"
                        size_hint: 1, .7
                        pos_hint: {"center_x": .5, "y": 0}
                        radius: [40,40, 0, 0]
                        Label:
                            id: design
                            canvas:
                                Color:
                                    rgba: 230/255, 230/255, 230/255, 1
                                RoundedRectangle:
                                    size: self.width/12, 3
                                    pos: self.width/2 - (self.width/8)/2, self.parent.height - 15
                                    radius: [2]
                        RecycleView:
                            id: rv
                            viewclass: 'ChatItem'
                            size_hint_y: 7
                            RecycleBoxLayout:
                                default_size: None, 100
                                default_size_hint: 1, None
                                size_hint_y: None
                                height: self.minimum_height
                                orientation: 'vertical'
##############################################################################################################################################################################################################
############# THE GROUP SCREEN ###############################################################################################################################################################################
##############################################################################################################################################################################################################                                               
        MDBottomNavigationItem:
            name: 'screen 2'
            text: 'Groups'
            icon: 'account-group-outline'
            badge_icon: "numeric-5"


            MDScreen:
                radius: [0, 0, 0, 0]
                md_bg_color: 0, 14/255, 8/255, 1
                AnchorLayout:
                    anchor_x: 'center'
                    anchor_y: 'top'
                    MDTopAppBar:
                        title: "Groups"
                        font_name: "fonts/Arial-MT-Black.ttf"
                        md_bg_color:0, 14/255, 8/255, 1
                        left_action_items: [["magnify", "This is the search button"]]
                        specific_text_color: 1, 1, 1, 1
                        right_action_items: [["circle-small"]]
                        elevation: 0

                MDFloatLayout:
                    
##################The first part of the MDTopBar######################################################################
                    MDIconButton:
                        icon: ''
                        icon_color: 1, 1, 1, 1
                        icon_size: '30dp'
                        theme_icon_color: "Custom"
                        pos_hint: {'right': 0.16, 'top': 0.99}
                        
                        canvas:
                            Color:
                                rgb: 59/255, 63/255, 59/255, 1
                            Line:
                                width: 1
                                circle: (self.center_x, self.center_y, min(self.width-2, self.height-2)/2, 0, 360)

###################The second part of the MDTopBar########################################################

                    # To hid the real MDTopAppBar right icon
                    MDBoxLayout:
                        size_hint: None, None
                        size: 100, 100
                        pos_hint: {'right': 0.98, 'top': 0.99}
                        md_bg_color: 0, 14/255, 8/255, 1
                    MDIconButton:
                        icon: 'account-multiple-plus-outline'
                        icon_color: 1, 1, 1, 1
                        icon_size: '30dp'
                        theme_icon_color: "Custom"
                        pos_hint: {'right': 0.98, 'top': 0.99}
                        
                        canvas:
                            Color:
                                rgb: 59/255, 63/255, 59/255, 1
                            Line:
                                width: 1
