<RootWidget>:
    Screen1:

<IdeaLabel2@Label>:
    size_hint: .4, .3
    font_size: "100dp"
    font_name: "fonts/Montserrat-Bold.ttf" 
    color: (1, 1, 1, 1)

<Screen1>:
    canvas.before:
        PushMatrix:
        Color:
            rgba: 0, 0, 0, 0
        Rectangle:
            size: self.size
            pos: self.pos
    canvas.after:
        PopMatrix:
    FloatLayout:
        IdeaLabel2:
            id: idealabel2_complete
            text: "iDea"
            pos_hint: {'center_y':0.97, 'center_x': 0.5}
            font_size: "30dp"
        BoxLayout:
            orientation: 'vertical'
            size_hint: .5, .4
            pos_hint: {'center_x': 0.27, 'center_y': 0.725}
            Label:
                id: share
                text: "Share"
                font_name: "Arial"
                font_size: "75dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
            Label:
                id: information
                text: "Information"
                font_name: "Arial"
                font_size: "75dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left':1}

            Label:
                id: easily
                text: "Easily"
                font_name: "Arial"
                font_size: "75dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left':1}
            Label:
                id: within_mtu
                text: "Within MTU"
                font_name: "Arial"
                font_size: "75dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left':1}
        BoxLayout:
            orientation: "vertical"
            size_hint: .5, .1
            pos_hint: {'center_x': 0.27, 'center_y': 0.45}
            Label:
                id: second_text_first_line
                text: "Our chat app is the perfect way to"
                font_name: "fonts/Montserrat-Light.ttf"
                font_size: "20dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
                color: (185/255, 193/255, 190/255, 1)
            Label:
                id: second_text_second_line
                text: "stay informed about Lectures and"
                font_name: "fonts/Montserrat-Light.ttf"
                font_size: "20dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
                color: (185/255, 193/255, 190/255, 1)
            Label:
                id: second_text_third_line
                text: "school activites"
                font_name: "fonts/Montserrat-Light.ttf"
                font_size: "20dp"
                size_hint_x: None
                size: self.texture_size
                pos_hint: {'left': 1}
                color: (185/255, 193/255, 190/255, 1)
        BoxLayout:
            orientation: "vertical"
            size_hint: .9, .07
            pos_hint: {'center_x': 0.5, 'center_y': 0.2}
            SmoothButton:
                id: sign_up_button
                text:"Sign Up"
                font_name: 'Arial'
                font_size: "15dp"
                color: (0, 14/255, 8/255, 1)
                on_press: self.back_color=(0.5, 0.5, 0.5, 1)
                on_release: self.back_color=(1, 1, 1, 1)

<SmoothButton@Button>:
    background_color: (0, 0, 0, 0)          
    background_normal: ''
    background_down: ''
    back_color: (1, 1, 1, 1)
    border_radius: [15]
    canvas.before:
        Color:
            rgba: self.back_color
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: self.border_radius